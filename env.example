# ─── Lead Capture Bot — Environment Config ───────────────────────────────────
# © 2025 By Fogle Unlimited | v1.0
# Rename this file to .env and fill in your values.

# Port the server listens on
PORT=3000

# Path to your Google Service Account JSON key file
GOOGLE_KEY_FILE=credentials.json

# Your Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# The tab name inside your Google Sheet where leads will be saved
SHEET_NAME=Leads
